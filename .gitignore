/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# package manager lock files (using pnpm)
package-lock.json
yarn.lock

# testing
/coverage

# next.js
/.next/
/out/
.next/cache/

# production
/build
/dist

# misc
.DS_Store
*.pem
.turbo/
.cache/
.contentlayer/
Thumbs.db

