.venv/
.windsurf/
.windsurf
.windsurfrc
.vscode/
.idea/
*.code-workspace
*.swp
*.swo
*~

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*.local
.env
.env.remote
.env.production

# vercel
.vercel

# supabase local artifacts
supabase/.branches/
supabase/.temp/

# remote opencode
logs/
tmp/
*.log
ecosystem.config.json
.pm2/
